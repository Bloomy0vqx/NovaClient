{
  "name": "nova-client",
  "version": "1.0.0",
  "description": "Nova Client - The ultimate Minecraft launcher with SolarTweaks proxy",
  "author": {
    "name": "Nova Team",
    "email": "supportccoaching@gmail.com"
  },
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:all": "npm run build && electron-builder -mw",
    "typecheck": "tsc --noEmit",
    "proxy:install": "cd proxy && npm install",
    "proxy:dev": "cd proxy && npx tsx watch src/proxy.ts"
  },
  "dependencies": {
    "lucide-react": "^0.441.0",
    "minecraft-launcher-core": "^3.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
