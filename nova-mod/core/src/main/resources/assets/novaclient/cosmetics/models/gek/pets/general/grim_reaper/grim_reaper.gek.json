{
  "type": "pet",
  "attached_bone": "SHOULDER",
  "model": "lunar:cosmetics/models/gek/pets/general/grim_reaper/grim_reaper.geo.json",
  "texture": "lunar:cosmetics/models/gek/pets/general/grim_reaper/grim_reaper.webp",
  "animation": "lunar:cosmetics/models/gek/pets/general/grim_reaper/grim_reaper.anim.json",
  "state_machine": {
    "name": "molang",
    "controllers": [
      {
        "name": "main_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "highspeed",
            "plays_when": "!q.is_swimming && (c.ground_speed_smoothed > 22) && !q.is_elytra_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "elytra",
            "plays_when": "q.is_elytra_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          },
          {
            "anim": "swimming",
            "plays_when": "q.is_swimming || q.is_elytra_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "deep",
            "plays_when": "q.distance_from_surface>=3 && q.is_in_water && !q.is_swimming",
            "transition_easing": "easeInOutSine"
          },
          {
            "anim": "surface",
            "plays_when": "q.distance_from_surface<=3 && q.is_in_water && !q.surface_blocked && !q.is_swimming",
            "transition_easing": "easeInOutSine"
          },
          {
            "anim": "sleeping",
            "plays_when": "(c.afk_timer >= 10) && !q.is_in_gui",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "16"
          },
          {
            "anim": "main",
            "plays_when": "!q.is_swimming && !q.is_elytra_flying && !(c.afk_timer >= 15)",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          }
        ]
      },
      {
        "name": "eyes_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "eyes",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          }
        ]
      },
      {
        "name": "particles_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "particles",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          }
        ]
      },
      {
        "name": "skulls_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "skulls",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          }
        ]
      }
    ]
  }
}