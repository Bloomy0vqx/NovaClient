{
  "type": "pet",
  "attached_bone": "SHOULDER",
  "model": "lunar:cosmetics/models/gek/pets/general/goldfish/goldfish.geo.json",
  "texture": "lunar:cosmetics/models/gek/pets/general/goldfish/goldfish.webp",
  "animation": "lunar:cosmetics/models/gek/pets/general/goldfish/goldfish.anim.json",
  "state_machine": {
    "name": "molang",
    "controllers": [
      {
        "name": "main_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "flying",
            "plays_when": "q.is_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "swimming",
            "plays_when": "q.is_swimming",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "afk",
            "plays_when": "(c.afk_timer >= 10) && !q.is_in_gui",
            "transition_easing": "easeOutBack"
          },
          {
            "anim": "main",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          }
        ]
      },
      {
        "name": "bubbles_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "bubbles",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          }
        ]
      }
    ]
  }
}