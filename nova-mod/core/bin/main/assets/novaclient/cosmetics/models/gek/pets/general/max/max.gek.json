{
  "type": "pet",
  "attached_bone": "SHOULDER",
  "model": "lunar:cosmetics/models/gek/pets/general/max/max.geo.json",
  "texture": "lunar:cosmetics/models/gek/pets/general/max/max.webp",
  "animation": "lunar:cosmetics/models/gek/pets/general/max/max.anim.json",
  "animated_texture": false,
  "state_machine": {
    "name": "molang",
    "controllers": [
      {
        "name": "main_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "elytra",
            "plays_when": "q.is_elytra_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          },
          {
            "anim": "swimming",
            "plays_when": "q.is_swimming",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "water",
            "plays_when": "q.is_in_water && !q.is_swimming",
            "transition_easing": "easeInOutSine"
          },
          {
            "anim": "main",
            "plays_when": "1",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "10"
          }
        ]
      }
    ]
  }
}