{
  "type": "pet",
  "attached_bone": "SHOULDER",
  "model": "lunar:cosmetics/models/gek/wings/summer_croc_wings/summer_croc_wings.geo.json",
  "texture": "lunar:cosmetics/models/gek/wings/summer_croc_wings/summer_croc_wings.webp",
  "animation": "lunar:cosmetics/models/gek/wings/summer_croc_wings/summer_croc_wings.anim.json",
  "state_machine": {
    "name": "molang",
    "controllers": [
      {
        "name": "main_controller",
        "default_transition_ticks": "15",
        "states": [
          {
            "anim": "moving",
            "plays_when": "q.absolute_speed>2 && !q.is_elytra_flying || q.is_flying",
            "transition_easing": "easeOutExpo"
          },
          {
            "anim": "flying",
            "plays_when": "q.is_elytra_flying && !in_water",
            "transition_easing": "easeOutExpo"
          },
          {
            "anim": "idle",
            "plays_when": "!query.is_flying && !query.is_in_water && !q.is_elytra_flying",
            "transition_easing": "easeOutSine"
          }
        ]
      },
      {
        "name": "gui_controller",
        "transition_ticks": "8",
        "states": [
          {
            "anim": "gui",
            "plays_when": "q.is_in_gui"
          }
        ]
      }
    ]
  }
}