{
  "type": "pet",
  "attached_bone": "SHOULDER",
  "model": "lunar:cosmetics/models/gek/pets/general/polarr_bear/polarr_bear.geo.json",
  "texture": "lunar:cosmetics/models/gek/pets/general/polarr_bear/polarr_bear.webp",
  "animation": "lunar:cosmetics/models/gek/pets/general/polarr_bear/polarr_bear.anim.json",
  "animated_texture": true,
  "state_machine": {
    "name": "molang",
    "controllers": [
      {
        "name": "main_controller",
        "default_transition_ticks": "8",
        "states": [
          {
            "anim": "elytra",
            "plays_when": "q.is_elytra_flying",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          },
          {
            "anim": "swimming",
            "plays_when": "q.is_swimming",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "9"
          },
          {
            "anim": "water",
            "plays_when": "q.is_in_water && !q.is_swimming",
            "transition_easing": "easeInOutSine"
          },
          {
            "anim": "idle",
            "plays_when": "(c.afk_timer >= 5) && !q.is_in_gui && !q.is_in_preview_model",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "2"
          },
          {
            "anim": "walk",
            "plays_when": "!((c.afk_timer >= 5) && !q.is_in_gui && !q.is_in_preview_model) || q.is_in_gui || q.is_in_preview_model && !q.is_raining",
            "transition_easing": "easeInOutSine",
            "transition_ticks": "10"
          }
        ]
      }
    ]
  }
}